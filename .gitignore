# Environment — never commit real keys
.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Runtime state — use freecode.example.json as template
freecode.json
!freecode.example.json
dashboard.log
dashboard.lock
*.lock

# Session data — per-project, never commit
.freecode/

# Frontend (Next.js has its own .gitignore in frontend/)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/next-env.d.ts

# Misc
.DS_Store
Thumbs.db
*.pem
repomix-output.xml
